# Django
SECRET_KEY=your-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
USE_SQLITE=True

# Email (Gmail app password recommended)
EMAIL=your@gmail.com
EMAIL_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your@gmail.com
ADMIN_ALERT_EMAIL=your@gmail.com

# Stock alerts
LOW_STOCK_THRESHOLD=5
LOW_STOCK_ALERT_COOLDOWN=21600

# Redis (Upstash / Render Redis) — powers catalog cache + Celery broker
REDIS_URL=redis://localhost:6379/0
# Optional separate broker URL (defaults to REDIS_URL)
# CELERY_BROKER_URL=redis://localhost:6379/0
USE_CELERY=True
# Keep false on Render unless you run a Celery worker (true blocks checkout with SMTP).
CELERY_TASK_ALWAYS_EAGER=false
# Do not set true on production web service — causes 502 on /api/orders/add/

FRONTEND_URL=http://localhost:3000

# Google Sign-In (Web client ID from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
