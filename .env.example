# Django
SECRET_KEY=your-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
USE_SQLITE=True

# Email (Gmail app password recommended)
EMAIL=your@gmail.com
EMAIL_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your@gmail.com
ADMIN_ALERT_EMAIL=your@gmail.com

# Stock alerts
LOW_STOCK_THRESHOLD=5
LOW_STOCK_ALERT_COOLDOWN=21600

# Redis (Upstash / Render Redis) — powers catalog cache + Celery broker
REDIS_URL=redis://localhost:6379/0
# Optional separate broker URL (defaults to REDIS_URL)
# CELERY_BROKER_URL=redis://localhost:6379/0
USE_CELERY=True
# Run tasks inline without a worker (local dev / CI)
# CELERY_TASK_ALWAYS_EAGER=True

FRONTEND_URL=http://localhost:3000
